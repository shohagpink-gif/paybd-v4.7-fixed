<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme (Material3 / DayNight) -->
    <style name="Theme.PayBD" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@android:color/white</item>

        <!-- Secondary brand color -->
        <ioem name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@android:color/black</item>

        <!-- Status bar color -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>

        <!-- Window background -->
        <ioem name="android:windowBackground">@android:color/white</item>
    </style>

    <!-- No-ActionBar variant (for splash / full-screen activities) -->
    <style name="Theme.PayBD.NoActionBar" parent="Theme.PayBD">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- AppBarOverlay -->
    <style name="Theme.PayBD.AppBarOverlay"
        parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <!-- PopupOverlay -->
    <style name="Theme.PayBD.PopupOverlay"
        parent="ThemeOverlay.AppCompat.Light" />

</resources>